# Copy to .env.local for local dev. For Vercel, add the same keys in Project → Settings → Environment Variables
# (Production + Preview). Do not commit real secrets to git.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Required so OAuth returns to YOUR domain (/sign-in/sso-callback), not Clerk Account Portal.
# Set the same values in Vercel Production. In Clerk Dashboard → Configure → Paths:
#   Sign-in URL: https://bloggieai.com/sign-in
#   Sign-up URL: https://bloggieai.com/sign-up
# → Developers → Allowed redirect URLs (add each):
#   https://bloggieai.com/sign-in/sso-callback
#   https://bloggieai.com/sign-up/sso-callback
#   http://localhost:3000/sign-in/sso-callback
#   http://localhost:3000/sign-up/sso-callback
# Production: Configure → Domains → add clerk.bloggieai.com (replaces *.clerk.accounts.dev in the address bar).
#
# Google sign-in says "You're signing back in to Clerk" until you use YOUR Google OAuth app:
# 1. Google Cloud Console → APIs & Services → OAuth consent screen → App name: "Bloggie AI"
# 2. Credentials → Create OAuth client (Web) → Authorized redirect URI = Clerk Dashboard copy
#    (Clerk → Configure → SSO connections → Google → "Use custom credentials" shows the URI)
# 3. Clerk Dashboard → Google → enable "Use custom credentials" → paste Client ID + Secret
#    Do this for Production (and Development if you want Bloggie AI locally too).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_OUT_FALLBACK_REDIRECT_URL=/sign-out

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for server-side writes (blog, business context, strategy). From Supabase → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
# After pulling: run SQL migrations in supabase/*.sql (especially 009_add_domain_to_business_context.sql, 010_enable_rls.sql, 012_blog_images_storage.sql) in Supabase → SQL Editor.
# Blog banner/CTA images are capped at 10MB (see src/lib/blogImageLimits.ts); oversized generated images are compressed or fall back to CDN URLs.

# Public site origin for OG URLs and persisted blog images (defaults to https://bloggieai.com; Vercel sets VERCEL_URL automatically).
# NEXT_PUBLIC_SITE_URL=https://bloggieai.com

# Gemini / Google AI Studio (https://aistudio.google.com/apikey)
# Used for LinkedIn agent, image banners (Imagen), and other Gemini calls.
GEMINI_API_KEY=
# Image generation model (Imagen on Gemini API). Veo is for video — set GEMINI_VIDEO_MODEL if you add video later.
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_VIDEO_MODEL=veo-3.1-generate-preview

# SEO Review Tools — readability + keyword density (optimize step)
# Readability: https://api.seoreviewtools.com/documentation/readability-score-api-content/
# Keyword density: https://api.seoreviewtools.com/documentation/seo-content-analysis-api/content/v-3-0/
SEO_REVIEW_TOOLS_API_KEY=

# AI Humanize — rewrite API (optimize step, humanize until ZeroGPT AI < 20%)
# https://aihumanize.io/api — model: 0=quality, 1=balance, 2=enhanced (default 2 for detector bypass)
AI_HUMANIZE_API_KEY=
AI_HUMANIZE_EMAIL=
# AI_HUMANIZE_MODEL=2

# ZeroGPT — AI text detection (optimize step)
# https://zerogpt.org/api — new keys: zgpt_sk_* (auto-uses api.zerogpt.org)
# Legacy zerogpt.com dashboard keys (UUID) auto-use api.zerogpt.com/detect/detectText
ZEROGPT_API_KEY=
# ZEROGPT_DETECT_URL=https://api.zerogpt.com/api/detect/detectText

# OpenAI (optional)
OPENAI_API_KEY=

# Azure OpenAI (API key auth; used by /api/faq/ai-generate and content agents)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_IMAGE_DEPLOYMENT=

# FAQ admin (AI FAQ): Next.js proxies `/api/faq/page` and `/api/faq/page/bulk` (Prod Push) to this upstream.
FAQ_UPSTREAM_BASE=https://iitkgp-portal-server.upgrad.com
# FAQ_KGP_UPSTREAM_BASE=
# FAQ_CU_UPSTREAM_BASE=
# FAQ_DYP_UPSTREAM_BASE=
# FAQ_DEMO_UPSTREAM_BASE=
# FAQ_KGP_LIVE_BASE_URL=
# FAQ_CU_LIVE_BASE_URL=
# FAQ_DYP_LIVE_BASE_URL=
# FAQ_DEMO_LIVE_BASE_URL=
# AI FAQ login for DYP tenant (defaults in code if unset)
# FAQ_DYP_USERNAME=
# FAQ_DYP_PASSWORD=
# FAQ_LIVE_BASE_URL=
# Optional: Bearer token for server-side calls when the browser does not send Authorization.
# FAQ_UPSTREAM_AUTHORIZATION=Bearer ...

# Prod push auth
PROD_PUSH_PASSWORD=
# Optional. If omitted, OTPs are signed with PROD_PUSH_PASSWORD.
PROD_PUSH_OTP_SECRET=

# YD Online MBA mirror (optional). If unset, /yd-online-mba uses a live-page iframe fallback.
# YD_ONLINE_MBA_HTML_PATH=
# YD_ONLINE_MBA_MIRROR_ROOT=
