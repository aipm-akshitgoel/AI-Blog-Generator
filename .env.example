# Copy to .env.local for local dev. For Vercel, add the same keys in Project → Settings → Environment Variables
# (Production + Preview). Do not commit real secrets to git.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for server-side writes (blog, business context, strategy). From Supabase → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini
GEMINI_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# Azure OpenAI (API key auth; used by /api/faq/ai-generate and content agents)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_IMAGE_DEPLOYMENT=

# FAQ admin (AI FAQ): Next.js proxies `/api/faq/page` and `/api/faq/page/bulk` (Prod Push) to this upstream.
FAQ_UPSTREAM_BASE=https://iitkgp-portal-server.upgrad.com
# FAQ_KGP_UPSTREAM_BASE=
# FAQ_CU_UPSTREAM_BASE=
# FAQ_DEMO_UPSTREAM_BASE=
# FAQ_KGP_LIVE_BASE_URL=
# FAQ_CU_LIVE_BASE_URL=
# FAQ_DEMO_LIVE_BASE_URL=
# FAQ_LIVE_BASE_URL=
# Optional: Bearer token for server-side calls when the browser does not send Authorization.
# FAQ_UPSTREAM_AUTHORIZATION=Bearer ...

# Prod push auth
PROD_PUSH_PASSWORD=
# Optional. If omitted, OTPs are signed with PROD_PUSH_PASSWORD.
PROD_PUSH_OTP_SECRET=

# YD Online MBA mirror (optional). If unset, /yd-online-mba uses a live-page iframe fallback.
# YD_ONLINE_MBA_HTML_PATH=
# YD_ONLINE_MBA_MIRROR_ROOT=
